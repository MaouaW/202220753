DECLARE
    my_date       DATE := SYSDATE;
    v_future_date DATE;
    v_months_bet  NUMBER(5,2);
BEGIN
    -- Add 45 days to today's date
    v_future_date := my_date + 45;
    v_months_bet := MONTHS_BETWEEN(v_future_date, my_date);
    DBMS_OUTPUT.PUT_LINE('Today: ' || TO_CHAR(my_date, 'Month dd, yyyy'));
    DBMS_OUTPUT.PUT_LINE('Future Date (+45 days): ' || TO_CHAR(v_future_date, 'Month dd, yyyy'));
    DBMS_OUTPUT.PUT_LINE('Months between the two dates: ' || v_months_bet);
END;

