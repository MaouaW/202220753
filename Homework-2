DECLARE  
        v_country_name countries.country_name%TYPE;  
    v_median_age   countries.median_age%TYPE;  
BEGIN  
    SELECT country_name, median_age 
    INTO v_country_name, v_median_age  
    FROM countries  
    WHERE country_name = 'Japan';  
    DBMS_OUTPUT.PUT_LINE('The median age in ' || v_country_name || ' is ' || v_median_age || '.');
EXCEPTION
    WHEN NO_DATA_FOUND THEN
        DBMS_OUTPUT.PUT_LINE('Country not found.');
    WHEN TOO_MANY_ROWS THEN
        DBMS_OUTPUT.PUT_LINE('Multiple rows returned.');
END;


DECLARE  
    v_country_name countries.country_name%TYPE;  
    v_median_age   countries.median_age%TYPE;  
    CURSOR c_country_cursor IS 
        SELECT country_name, median_age  
        FROM countries  
        WHERE country_name = 'Japan';  
BEGIN  
    OPEN c_country_cursor;
    FETCH c_country_cursor INTO v_country_name, v_median_age;
    IF c_country_cursor%FOUND THEN
        DBMS_OUTPUT.PUT_LINE('The median age in ' || v_country_name || ' is ' || v_median_age || '.');
    ELSE
        DBMS_OUTPUT.PUT_LINE('No record found for Japan.');
    END IF;
    CLOSE c_country_cursor;  
END;

