    country_name VARCHAR2(50),
    median_age   NUMBER(6, 2)
);
INSERT INTO countries (country_name, median_age) VALUES ('Japan', 49.5);
INSERT INTO countries (country_name, median_age) VALUES ('Germany', 47.8);
INSERT INTO countries (country_name, median_age) VALUES ('Canada', 41.1);
COMMIT;
