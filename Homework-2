DECLARE
    today DATE := SYSDATE;
        tomorrow today%TYPE;
BEGIN
    DBMS_OUTPUT.PUT_LINE('Hello World');
    tomorrow := today + 1;
    DBMS_OUTPUT.PUT_LINE('Today is: ' || today);
    DBMS_OUTPUT.PUT_LINE('Tomorrow will be: ' || tomorrow);
END;
