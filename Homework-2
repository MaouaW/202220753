DECLARE
    my_date    DATE := SYSDATE;
    v_last_day DATE;
BEGIN
    DBMS_OUTPUT.PUT_LINE('Formatted Today: ' || TO_CHAR(my_date, 'Month dd, yyyy'));
    v_last_day := LAST_DAY(my_date);
    DBMS_OUTPUT.PUT_LINE('Last Day of this Month: ' || TO_CHAR(v_last_day, 'Month dd, yyyy'));
END;

