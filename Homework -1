SELECT 
    c.customer_id,
    c.name,
    COUNT(o.order_id) AS total_orders
FROM Customers c
LEFT JOIN Orders o 
    ON c.customer_id = o.customer_id
GROUP BY c.customer_id, c.name;

2)
SELECT customer_id, name
FROM (
    SELECT 
        c.customer_id,
        c.name,
        COUNT(o.order_id) AS total_orders
    FROM Customers c
    LEFT JOIN Orders o 
        ON c.customer_id = o.customer_id
    GROUP BY c.customer_id, c.name
) AS customer_orders
WHERE total_orders > (
    SELECT AVG(order_count)
    FROM (
        SELECT COUNT(*) AS order_count
        FROM Orders
        GROUP BY customer_id
    ) AS avg_table
);

